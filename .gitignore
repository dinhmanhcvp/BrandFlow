# ============================================================
#  BrandFlow .gitignore
#  Full-Stack: Next.js (Frontend) + Python / FastAPI (Backend)
# ============================================================

# ------------------------------------------------------------------
# 🔐 SECURITY — Environment variables & secrets (NEVER commit these)
# ------------------------------------------------------------------
.env
.env.*
*.env
secrets.json
*.pem
*.key

# ------------------------------------------------------------------
# 🐍 Python / FastAPI
# ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
venv/
env/
.venv/
.env/
ENV/

# Database files
*.sqlite3
*.db

# Pytest
.pytest_cache/
*.log
test_report*.txt
test_results*.txt
output*.txt

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
site-packages/

# ChromaDB local vector store (can be regenerated)
chroma_db/

# Temp uploads directory
temp_uploads/

# ------------------------------------------------------------------
# ⚛️  Node.js / Next.js
# ------------------------------------------------------------------
node_modules/
.next/
out/
build/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Vercel
.vercel

# TypeScript incremental compilation
*.tsbuildinfo
next-env.d.ts

# ------------------------------------------------------------------
# 💻  Operating System
# ------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

.worktrees/
